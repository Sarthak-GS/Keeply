{
  "manifest_version": 3,
  "name": "Keeply Helper",
  "version": "1.0",
  "description": "Autosaves credentials to your Keeply vault.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://keeply-liard.vercel.app/*",
    "https://keeply-o8ni.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
